{
  "name": "codedpixels",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "functions"
  ],
  "scripts": {
    "dev": "turbo run dev --filter=@codedpixels/marketing",
    "dev:marketing": "turbo run dev --filter=@codedpixels/marketing",
    "dev:builder": "turbo run dev --filter=@codedpixels/builder",
    "dev:renderer": "turbo run dev --filter=@codedpixels/site-renderer",
    "dev:preview": "node scripts/dev-preview-stack.mjs",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test:e2e": "playwright test --config playwright.config.ts",
    "test:e2e:spine": "playwright test --config playwright.config.ts apps/marketing/e2e/spine.spec.ts",
    "test:rules": "firebase emulators:exec --only firestore \"vitest run --config vitest.rules.config.ts\"",
    "test:lighthouse": "node scripts/lighthouse-budget.mjs",
    "emulators": "firebase emulators:start --only auth,firestore,functions,storage",
    "emulators:export": "firebase emulators:export ./firebase-export",
    "validate:templates": "npm run validate:templates --workspace=@codedpixels/templates",
    "new-template": "npm run new-template --workspace=@codedpixels/templates",
    "seed:templates": "npm run seed:templates --workspace=@codedpixels/templates",
    "seed:templates:emulator": "npm run seed:templates:emulator --workspace=@codedpixels/templates",
    "seed:template-demos": "npm run seed:template-demos --workspace=@codedpixels/templates",
    "seed:template-demos:emulator": "npm run seed:template-demos:emulator --workspace=@codedpixels/templates",
    "generate:template-thumbnails": "node scripts/generate-template-thumbnails.mjs",
    "deploy:production": "node scripts/deploy-production.mjs",
    "verify:production:dns": "node scripts/verify-production-dns.mjs",
    "verify:production:infra": "node scripts/verify-production-infra.mjs",
    "verify:production:probes": "node scripts/verify-production-probes.mjs"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.1",
    "@lhci/cli": "^0.14.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^20",
    "eslint": "^8.57.0",
    "firebase-tools": "^14.27.0",
    "sharp": "^0.34.5",
    "turbo": "^2.5.4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  },
  "packageManager": "npm@10.9.2"
}
