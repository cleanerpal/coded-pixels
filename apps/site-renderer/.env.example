# On-demand ISR revalidation secret — must match root REVALIDATE_SECRET (B3-001)
REVALIDATE_SECRET=

# Pin tenant slug when Host is localhost:3002 (site-renderer-architecture.md §3.3)
SITE_RENDERER_DEV_SLUG=

# Firebase Admin SDK — server-side slug + published content reads (B4-001)
FIREBASE_PROJECT_ID=codedpixels
