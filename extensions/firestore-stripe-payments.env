# Stripe Firebase Extension — Run Payments with Stripe (Q63)
# Install: firebase ext:install stripe/firestore-stripe-payments --project=codedpixels
# Secrets (STRIPE_API_KEY, STRIPE_WEBHOOK_SECRET) — set in Firebase Console only; never commit.

STRIPE_API_KEY=sk_test_REPLACE_WITH_DASHBOARD_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_EXTENSION_WEBHOOK_SECRET

# Collection paths — align with firestore-schema.md §8
CUSTOMERS_COLLECTION=customers
PRODUCTS_COLLECTION=products

# Sync new Auth users to Stripe customers on first checkout
SYNC_USERS_ON_CREATE=Do not sync

# Customer portal (B8) — enable when live
CREATE_CHECKOUT_SESSION_MIN_INSTANCES=0
