# Resize Images Extension — codedpixels-project-plan.md Q64
# Install: firebase ext:install firebase/storage-resize-images --project=codedpixels
# Aligned with Dr. Nora Patel on Q44, Dr. Clara Voss on Q64.
#
# Pipeline: Builder upload → ClamAV Function (onObjectFinalized) → this Extension
# generates 400px WebP thumbnails (filename suffix _400x400.webp).

LOCATION=europe-west2
IMG_BUCKET=${STORAGE_BUCKET}
IMG_SIZES=400x400
DELETE_ORIGINAL_FILE=false
MAKE_PUBLIC=false
IMAGE_TYPE=webp
IS_ANIMATED=false
DO_BACKFILL=false
REGENERATE_TOKEN=true
SHARP_OPTIONS={"fit":"inside","withoutEnlargement":true}
