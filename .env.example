# Google Analytics 4 — loads only after analytics cookie consent (ENG-022)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Firebase web app — required for signup/waitlist Callables (INF-003, ENG-023)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=codedpixels
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Connect to local emulators (set true when running npm run emulators)
NEXT_PUBLIC_USE_FIREBASE_EMULATORS=false

# Checkout mode: simulated (default) | stripe (B6-001 Extension live)
NEXT_PUBLIC_CHECKOUT_MODE=simulated

# Firebase App Check — required before PII Callables in production (INF-003)
# Without a site key, the browser cannot mint App Check tokens in local dev.
NEXT_PUBLIC_FIREBASE_APP_CHECK_RECAPTCHA_SITE_KEY=

# Functions emulator only — set true when App Check debug token is not configured
DISABLE_APP_CHECK=

# Sentry — marketing site error monitoring (INF-004)
# Set both DSN values to the same project DSN when enabling Sentry.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# Optional build-time source map upload
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
SENTRY_ENVIRONMENT=development

# Site renderer on-demand ISR revalidation (B3-001 — site-renderer-architecture.md §7.3)
REVALIDATE_SECRET=

# Cloud Functions → site-renderer revalidation caller (B3-001)
SITE_RENDERER_URL=http://localhost:3002
