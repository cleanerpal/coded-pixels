# Google Analytics 4 — loads only after analytics cookie consent (ENG-022)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Firebase App Check — required before PII Callables in production (INF-003)
# Without a site key, the browser cannot mint App Check tokens in local dev.
NEXT_PUBLIC_FIREBASE_APP_CHECK_RECAPTCHA_SITE_KEY=

# Functions emulator only — set true when App Check debug token is not configured
DISABLE_APP_CHECK=

# Sentry — marketing site error monitoring (INF-004)
# Set both DSN values to the same project DSN when enabling Sentry.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# Optional build-time source map upload
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
SENTRY_ENVIRONMENT=development
